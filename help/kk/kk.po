"\n"
"[merge]\n"
"    tool = meld\n"
msgstr ""
"\n"
"[merge]\n"
"    tool = meld\n"

#. (itstool) path: page/p
#: C/resolving-conflicts.page:31
msgid ""
"to <file>.git/gitconfig</file>. See the <app>git mergetool</app> manual for "
