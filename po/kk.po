msgid "Scanning…"
msgstr "Сканерленуде…"

#. Translators: This error message is shown when no
#. repository of this type is found.
#: meld/vcview.py:349
#, python-format
msgid "%(name)s (not found)"
msgstr "%(name)s (табылмады)"

#. Translators: This error message is shown when a version
#. control binary isn't installed.
#: meld/vcview.py:353
#, python-format
msgid "%(name)s (%(cmd)s not installed)"
msgstr "%(name)s (%(cmd)s орнатылмаған)"

#. Translators: This error message is shown when a version
#. controlled repository is invalid.
#: meld/vcview.py:357
#, python-format
msgid "%(name)s (invalid repository)"
msgstr "%(name)s (жарамсыз репозиторий)"

#: meld/vcview.py:371
msgid "No valid version control system found in this folder"
msgstr "Бұл бумада жарамды нұсқаны басқару жүйесі табылмады"

#: meld/vcview.py:373
msgid "Choose which version control system to use"
msgstr "Қай нұсқаны басқару жүйесін таңдау"

#. TRANSLATORS: This is the name of the version control
#. system being used, e.g., "Git" or "Subversion"
#: meld/vcview.py:429
#, python-brace-format
msgid "{vc} comparison:"
msgstr "{vc} салыстыруы:"

#. Initial yield so when we add this to our tasks, we don't
#. create iterators that may be invalidated.
#: meld/vcview.py:444
msgid "Scanning repository"
msgstr "Репозиторийді сканерлеу"

#: meld/vcview.py:473
#, python-format
msgid "Scanning %s"
msgstr "%s сканерленуде"

#: meld/vcview.py:512
msgid "(Empty)"
msgstr "(Бос)"

