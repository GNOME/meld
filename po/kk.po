msgstr "%s (жергілікті, біріктірілген, қашықтағы)"

#: meld/vcview.py:574
#, python-format
msgid "%s (remote, merge, local)"
msgstr "%s (қашықтағы, біріктірілген, жергілікті)"

#: meld/vcview.py:585
#, python-format
msgid "%s — repository"
msgstr "%s — репозиторий"

#: meld/vcview.py:591
#, python-format
msgid "%s (working, repository)"
msgstr "%s (жұмыс, репозиторий)"

#: meld/vcview.py:595
#, python-format
msgid "%s (repository, working)"
msgstr "%s (репозиторий, жұмыс)"

#: meld/vcview.py:760
msgid "Remove folder and all its files?"
msgstr "Буманы және оның барлық файлдарын өшіру керек пе?"

#: meld/vcview.py:762
msgid "This will remove all selected files and folders, and all files within any selected folders, from version control."
msgstr ""
"Бұл әрекет барлық таңдалған файлдар мен бумаларды, және таңдалған бумалардың ішіндегі барлық файлдарды нұсқаны басқару "
"жүйесінен өшіреді."

