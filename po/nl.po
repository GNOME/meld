#: bin/meld:274
#, c-format
msgid "Meld requires %s."
msgstr "Meld vereist %s."

#: data/org.gnome.Meld.desktop.in.in:2
#: meld/resources/data/org.gnome.Meld.metainfo.xml.in.in:10
#: meld/resources/ui/appwindow.ui:7
msgid "Meld"
msgstr "Meld"

#: data/org.gnome.Meld.desktop.in.in:3
msgid "Diff Viewer"
msgstr "Diff weergeven"

#: data/org.gnome.Meld.desktop.in.in:4
#: meld/resources/data/org.gnome.Meld.metainfo.xml.in.in:11
msgid "Compare and merge your files"
msgstr "Vergelijken en samenvoegen van uw bestanden"

#. TRANSLATORS: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Meld.desktop.in.in:6
msgid "diff;merge;"
msgstr "diff;merge;verschil;samenvoegen;"

#: data/mime/org.gnome.Meld.xml.in:4
msgid "Meld comparison description"
msgstr "Meld beschrijving vergelijking"

#: data/org.gnome.Meld.gschema.xml:43
msgid "Default window width"
msgstr "Standaardbreedte venster"

#: data/org.gnome.Meld.gschema.xml:47
msgid "Default window height"
msgstr "Standaardhoogte venster"

#: data/org.gnome.Meld.gschema.xml:51
msgid "Default window maximized state"
msgstr "Standaard gemaximaliseerde status venster"

#: data/org.gnome.Meld.gschema.xml:64
msgid "Style Variant"
msgstr "Stijlvariant"

#: data/org.gnome.Meld.gschema.xml:65
msgid ""
"Whether to force the light or dark variant of the GTK theme. If set to "
"'default', the application will follow the system default variant."
msgstr "Of de lichte of donkere variant van het GTK-thema moet worden gebruikt. Indien ingesteld op 'default', zal de toepassing de variant voor de systeemstandaard volgen."

#: data/org.gnome.Meld.gschema.xml:71
msgid "Additional automatically detected text encodings"
msgstr "Aanvullende automatisch gedetecteerde tekstcoderingen"

#: data/org.gnome.Meld.gschema.xml:72
msgid ""
"Meld will use these text encodings to try to decode loaded text files before "
"trying any other encodings. In addition to the encodings in this list, UTF-8 "
"and the current locale-default encoding will always be used; other encodings "
"may also be tried, depending on the user’s locale."
msgstr "Meld zal deze tekstcoderingen gebruiken om te proberen geladen tekstbestanden te decoderen voordat het andere coderingen probeert. In aanvulling op de coderingen in deze lijst, zullen UTF-8 en de huidige standaard-locale codering worden gebruikt; andere coderingen zouden ook geprobeerd kunnen worden, afhankelijk van de locale van de gebruiker."

#: data/org.gnome.Meld.gschema.xml:79
msgid "Width of an indentation step"
msgstr "Breedte voor stap inspringen"

#: data/org.gnome.Meld.gschema.xml:80
msgid "The number of spaces to use for a single indent step"
msgstr "Het aantal spaties  om te gebruiken voor een stap van inspringen"

#: data/org.gnome.Meld.gschema.xml:84
msgid "Whether to indent using spaces or tabs"
msgstr "Of inspringen tabs of spaties gebruikt"

#: data/org.gnome.Meld.gschema.xml:85
msgid "If true, any new indentation will use spaces instead of tabs."
msgstr "Indien true zal een nieuwe inspringing spaties gebruiken, in plaats van tabs."

#: data/org.gnome.Meld.gschema.xml:89 meld/resources/ui/statusbar-menu.ui:5
msgid "Show line numbers"
msgstr "Regelnummers weergeven"

#: data/org.gnome.Meld.gschema.xml:90
msgid "If true, line numbers will be shown in the gutter of file comparisons."
msgstr "Indien true zullen in de marge regelnummers worden weergegeven voor bestandsvergelijkingen."

#: data/org.gnome.Meld.gschema.xml:94
msgid "Highlight syntax"
msgstr "Syntaxis accentueren"

#: data/org.gnome.Meld.gschema.xml:95
msgid ""
"Whether to highlight syntax in comparisons. Because of Meld’s own color "
"highlighting, this is off by default."
msgstr "Of syntaxis in vergelijkingen moet worden geaccentueerd. Wegens het eigen in kleur accentueren van Meld is dit standaard uitgeschakeld."

#: data/org.gnome.Meld.gschema.xml:99
msgid "Color scheme to use for syntax highlighting"
msgstr "Kleurenschema om te gebruiken voor accentueren van syntaxis"

#: data/org.gnome.Meld.gschema.xml:100
msgid "Used by GtkSourceView to determine colors for syntax highlighting"
msgstr "Gebruikt door GtkSourceView om kleuren te bepalen voor accentueren van syntaxis"

#: data/org.gnome.Meld.gschema.xml:104
msgid "Draw whitespace"
msgstr "Witruimte tekenen"

#: data/org.gnome.Meld.gschema.xml:105
msgid ""
"If true, whitespace characters will be drawn in comparisons even if they are "
"not in a changed area."
msgstr "Indien true zullen tekens voor witruimte in vergelijkingen worden getekend, zelfs als ze niet in een gewijzigd gebied staan."

#: data/org.gnome.Meld.gschema.xml:114
msgid "Wrap mode"
msgstr "Modus Doorloop"

#: data/org.gnome.Meld.gschema.xml:115
msgid ""
"Lines in file comparisons will be wrapped according to this setting, either "
"not at all ('none'), at any character ('char') or only at the end of words "
"('word')."
msgstr "Regels in bestandsvergelijkingen zullen overeenkomstig deze instelling doorlopen, ofwel helemaal niet ('none'), op een teken ('char') of alleen aan het einde van woorden ('word')."

#: data/org.gnome.Meld.gschema.xml:122 meld/resources/ui/statusbar-menu.ui:13
msgid "Highlight current line"
msgstr "Huidige regel accentueren"

#: data/org.gnome.Meld.gschema.xml:123
msgid ""
"If true, the line containing the cursor will be highlighted in file "
"comparisons."
msgstr "Indien true zal de regel die de cursor bevat worden geaccentueerd in bestandsvergelijkingen."

#: data/org.gnome.Meld.gschema.xml:127
msgid "Use the system default monospace font"
msgstr "Standaard systeem monospace lettertype gebruiken"

#: data/org.gnome.Meld.gschema.xml:128
msgid ""
"If false, custom-font will be used instead of the system monospace font."
msgstr "Indien false zal een aangepast lettertype worden gebruikt, in plaats van het monospace lettertype van het systeem."

#: data/org.gnome.Meld.gschema.xml:132
msgid "Custom font"
msgstr "Aangepast lettertype"

#: data/org.gnome.Meld.gschema.xml:133
msgid ""
"The custom font to use, stored as a string and parsed as a Pango font "
"description."
msgstr "Het te gebruiken aangepaste lettertype, opgeslagen als een tekenreeks en geparset als een Pango lettertypebeschrijving."

#: data/org.gnome.Meld.gschema.xml:139
msgid "Show overview source map"
msgstr "Overzicht bronmap weergeven"

#: data/org.gnome.Meld.gschema.xml:140
msgid ""
"If true, file comparisons will have paired source maps for compared files."
msgstr "Indien true zullen bestandsvergelijkingen gepaarde bronmappen voor vergeleken bestanden hebben."

#: data/org.gnome.Meld.gschema.xml:145
msgid "Style of overview map"
msgstr "Stijl overzichtsmap"

#: data/org.gnome.Meld.gschema.xml:146
msgid "Style options for how the overview map is displayed."
msgstr "Stijlopties voor hoe de overzichtsmap wordt weergegeven."

#: data/org.gnome.Meld.gschema.xml:152
msgid "Ignore blank lines when comparing files"
msgstr "Blanco regels negeren bij vergelijken bestanden"

#: data/org.gnome.Meld.gschema.xml:153
msgid ""
"If true, blank lines will be trimmed when highlighting changes between files."
msgstr "Indien true zullen blanco regels worden afgebroken bij het accentueren van wijzigingen tussen bestanden."

#: data/org.gnome.Meld.gschema.xml:160
msgid "Use the system default editor"
msgstr "Standaard systeembewerker gebruiken"

#: data/org.gnome.Meld.gschema.xml:161
msgid ""
"If false, custom-editor-command will be used instead of the system editor "
"when opening files externally."
msgstr "Indien false zal een opdracht voor een aangepaste bewerker worden gebruikt in plaats van de systeembewerker bij het extern openen van bestanden."

#: data/org.gnome.Meld.gschema.xml:165
msgid "The custom editor launch command"
msgstr "De opdracht voor het starten van de aangepaste bewerker"

#: data/org.gnome.Meld.gschema.xml:166
msgid ""
"The command used to launch a custom editor. Some limited templating is "
"supported here; at the moment '{file}' and '{line}' are recognised tokens."
msgstr "De opdracht die wordt gebruikt om een aangepaste bewerker te starten. Enige beperkte mogelijkheid voor sjablonen wordt hier ondersteund; op dit moment zijn '{file}' en '{line}' herkende tokens."

#: data/org.gnome.Meld.gschema.xml:172
msgid "Columns to display"
msgstr "Weer te geven kolommen"

#: data/org.gnome.Meld.gschema.xml:173
msgid ""
"List of column names in folder comparison and whether they should be "
"displayed."
msgstr "Lijst met kolomnamen bij bestandsvergelijkingen en of die zouden moeten worden weergegeven."

#: data/org.gnome.Meld.gschema.xml:177 meld/resources/ui/preferences.ui:241
msgid "Ignore symbolic links"
msgstr "Symbolische links negeren"

#: data/org.gnome.Meld.gschema.xml:178
msgid ""
"If true, folder comparisons do not follow symbolic links when traversing the "
"folder tree."
msgstr "Indien true zullen mapvergelijkingen geen symbolische links volgen bij het navigeren door de mappenboom."

#: data/org.gnome.Meld.gschema.xml:182
msgid "Use shallow comparison"
msgstr "Oppervlakkig vergelijken gebruiken"

#: data/org.gnome.Meld.gschema.xml:183
msgid ""
"If true, folder comparisons compare files based solely on size and mtime, "
"considering files to be identical if their size and mtime match, and "
"different otherwise."
msgstr "Indien true zullen mapvergelijkingen bestanden slechts vergelijken op grootte en mtime, waarbij bestanden identiek worden geacht als hun grootte en mtime overeenkomen en anders verschillend zijn."

#: data/org.gnome.Meld.gschema.xml:187
msgid "File timestamp resolution"
msgstr "Oplossen tijdstempel bestand"

#: data/org.gnome.Meld.gschema.xml:188
msgid ""
"When comparing based on mtime, this is the minimum difference in nanoseconds "
"between two files before they’re considered to have different mtimes. This "
"is useful when comparing files between filesystems with different timestamp "
"resolution."
msgstr "Bij het vergelijken gebaseerd op mtime is dit het minimale verschil in nanoseconden tussen twee bestanden voordat ze worden geacht verschillende mtimes te hebben. Dit is nuttig bij het vergelijken van bestanden tussen bestandssystemen met verschillend oplossen van tijdstempel."

#: data/org.gnome.Meld.gschema.xml:192 meld/resources/ui/preferences.ui:250
msgid "Apply text filters during folder comparisons"
msgstr "Tekstfilters toepassen bij mapvergelijkingen"

#: data/org.gnome.Meld.gschema.xml:193
msgid ""
"If true, folder comparisons that compare file contents also apply active "
"text filters and the blank line trimming option, and ignore newline "
"differences."
msgstr "Indien true zullen mapvergelijkingen die ook bestandsinhoud vergelijken ook actieve tekstfilters toepassen en de optie voor afbreken van blanco regels, en negeren verschillen voor nieuwe regels."

#: data/org.gnome.Meld.gschema.xml:197
msgid "File status filters"
msgstr "Filters bestandsstatus"

#: data/org.gnome.Meld.gschema.xml:198
msgid "List of statuses used to filter visible files in folder comparison."
msgstr "Lijst met statussen die wordt gebruikt voor het filteren van zichtbare bestanden bij mapvergelijkingen."

#: data/org.gnome.Meld.gschema.xml:204
msgid "Show the version control console output"
msgstr "Uitvoer van console versiebeheer weergeven"

#: data/org.gnome.Meld.gschema.xml:205
msgid ""
"If true, a console output section will be shown in version control views, "
"showing the commands run for version control operations."
msgstr "Indien true zal een gedeelte voor uitvoer van de console worden weergegeven in weergaven van versiebeheer, dat de uitgevoerde opdrachten voor bewerkingen van versiebeheer zal laten zien."

#: data/org.gnome.Meld.gschema.xml:209
msgid "Version control pane position"
msgstr "Positie paneel Versiebeheer"

#: data/org.gnome.Meld.gschema.xml:210
msgid ""
"This is the height of the main version control tree when the console pane is "
"shown."
msgstr "Dit is de hoogte van het hoofdvenster van versiebeheer als het paneel voor de console wordt weergegeven."

#: data/org.gnome.Meld.gschema.xml:214
msgid "Present version comparisons as left-local/right-remote"
msgstr "Huidige versievergelijkingen als links-lokaal/rechts-afstand"

#: data/org.gnome.Meld.gschema.xml:215
msgid ""
"If true, version control comparisons will use a left-is-local, right-is-"
"remote scheme to determine what order to present files in panes. Otherwise, "
"a left-is-theirs, right-is-mine scheme is used."
msgstr "Indien true zullen vergelijkingen van versiebeheer een schema van links-is-lokaal, rechts-is-op afstand gebruiken om te bepalen in welke volgorde bestanden in panelen weer te geven. Anders wordt een schema van links-is-hun, rechts-is-mijn gebruikt."

#: data/org.gnome.Meld.gschema.xml:219
msgid "Order for files in three-way version control merge comparisons"
msgstr "Volgorde van bestanden voor drieweg samenvoegvergelijkingen voor versiebeheer"

#: data/org.gnome.Meld.gschema.xml:220
msgid ""
"Choices for file order are remote/merged/local and local/merged/remote. This "
"preference only affects three-way comparisons launched from the version "
"control view, so is used solely for merges/conflict resolution within Meld."
msgstr "Keuzen voor bestandsvolgorde zijn op afstand/samengevoegd/lokaal en lokaal/samengevoegd/op afstand. Deze voorkeur beïnvloedt alleen drieweg vergelijkingen in de weergave van versiebeheer en wordt dus uitsluitend gebruikt voor het oplossen van conflicten bij samenvoegen binnen Meld."

#: data/org.gnome.Meld.gschema.xml:224
msgid "Show margin in commit message editor"
msgstr "Marge weergeven in bewerker voor bericht commit"

#: data/org.gnome.Meld.gschema.xml:225
msgid ""
"If true, a guide will be displayed to show what column the margin is at in "
"the version control commit message editor."
msgstr "Indien true zal een hulplijn worden weergegeven om aan te geven op welke marge de kolom staat in de bewerker voor het bericht van de commit voor versiebeheer."

#: data/org.gnome.Meld.gschema.xml:229
msgid "Margin column in commit message editor"
msgstr "Marge kolom in bewerker voor bericht commit"

#: data/org.gnome.Meld.gschema.xml:230
msgid ""
"The column at which to show the margin in the version control commit message "
"editor."
msgstr "De kolom waarvoor de marge moet worden weergegeven in de bewerker voor het bericht van de commit voor versiebeheer."

#: data/org.gnome.Meld.gschema.xml:234
msgid "Automatically hard-wrap commit messages"
msgstr "Automatische berichten voor commit met harde doorloop"

#: data/org.gnome.Meld.gschema.xml:235
msgid ""
"If true, the version control commit message editor will hard-wrap (i.e., "
"insert line breaks) at the commit margin before commit."
msgstr "Indien true zal de bewerker voor het bericht van de commit voor versiebeheer hard doorlopen (d.i. regeleinden invoegen) bij de marge van de commit voor het indienen."

#: data/org.gnome.Meld.gschema.xml:239
msgid "Version control status filters"
msgstr "Statusfilters versiebeheer"

#: data/org.gnome.Meld.gschema.xml:240
msgid ""
"List of statuses used to filter visible files in version control comparison."
msgstr "Lijst met statussen die wordt gebruikt voor het filteren van zichtbare bestanden in vergelijkingen van versiebeheer."

#.
#. Translators: A list of default filters, each of which is
#. composed of a (name, enabled, pattern) in GVariant syntax.
#. Please only translate the name of each filter.
#: data/org.gnome.Meld.gschema.xml:250
msgid ""
"[\n"
"              (\"Backups\", true, \"#*# .#* ~* *~ *.{orig,bak,swp}\"),\n"
"              (\"OS-Specific Metadata\", true, \".DS_Store ._* .Spotlight-"
"V100 .Trashes Thumbs.db Desktop.ini\"),\n"
"              (\"Version Control\", true, "
"\"_MTN .bzr .svn .svn .hg .fslckout _FOSSIL_ .fos CVS "
"_darcs .git .svn .osc\"),\n"
"              (\"Binaries\", true, \"*.{pyc,a,obj,o,so,la,lib,dll,exe}\"),\n"
"              (\"Media\", false, \"*."
"{jxl,jpg,jpeg,gif,png,avif,webp,heif,heic,bmp,tif,tiff,raw,dng,cr2,wav,wave,mp3,ogg,oga,vorbis,spx,opus,flac,ac3,aac,aif,aiff,aifc,alac,m4a,3gp,wma,aup,aup3,avi,mov,mpg,mpeg,mp4,m4v,webm,ogv,flv,xcf,xpm,ora,kra,psd,psp}"
"\")\n"
"            ]"
msgstr "[\n"
"              (\"Backups\", true, \"#*# .#* ~* *~ *.{orig,bak,swp}\"),\n"
"              (\"OS-Specific Metadata\", true, \".DS_Store ._* .Spotlight-V100 .Trashes Thumbs.db Desktop.ini\"),\n"
"              (\"Version Control\", true, \"_MTN .bzr .svn .svn .hg .fslckout _FOSSIL_ .fos CVS _darcs .git .svn .osc\"),\n"
"              (\"Binaries\", true, \"*.{pyc,a,obj,o,so,la,lib,dll,exe}\"),\n"
"              (\"Media\", false, \"*.{jxl,jpg,jpeg,gif,png,avif,webp,heif,heic,bmp,tif,tiff,raw,dng,cr2,wav,wave,mp3,ogg,oga,vorbis,spx,opus,flac,ac3,aac,aif,aiff,aifc,alac,m4a,3gp,wma,aup,aup3,avi,mov,mpg,mpeg,mp4,m4v,webm,ogv,flv,xcf,xpm,ora,kra,psd,psp}\")\n"
"            ]"

#: data/org.gnome.Meld.gschema.xml:259
msgid "Filename-based filters"
msgstr "Op bestandsnaam gebaseerde filters"

#: data/org.gnome.Meld.gschema.xml:260
msgid ""
"List of predefined filename-based filters that, if active, will remove "
"matching files from a folder comparison."
msgstr "Lijst met vooraf gedefinieerde op bestandsnamen gebaseerde filters die, indien actief, overeenkomende bestanden uit een mapvergelijking zullen verwijderen."

#.
#. Translators: A list of default filters, each of which is
#. composed of a (name, enabled, pattern) in GVariant syntax.
#. Please only translate the name of each filter.
#: data/org.gnome.Meld.gschema.xml:268
msgid ""
"[\n"
"              (\"CVS/SVN Keywords\", false, \"\\\\$\\\\w+(:[^\\\\n$]+)?\\\\$"
"\"),\n"
"              (\"C++ Comment\", false, \"//.*\"),\n"
"              (\"C Comment\", false, \"/\\\\*.*?\\\\*/\"),\n"
"              (\"All Whitespace\", false, \"[ \\\\t\\\\r\\\\f\\\\v]*\"),\n"
"              (\"Leading Whitespace\", false, \"^[ \\\\t\\\\r\\\\f\\"
"\\v]*\"),\n"
"              (\"Trailing Whitespace\", false, \"[ \\\\t\\\\r\\\\f\\\\v]*$"
"\"),\n"
"              (\"Script Comment\", false, \"#.*\")\n"
"            ]"
msgstr "[\n"
"              (\"CVS/SVN Keywords\", false, \"\\\\$\\\\w+(:[^\\\\n$]+)?\\\\$\"),\n"
"              (\"C++ Comment\", false, \"//.*\"),\n"
"              (\"C Comment\", false, \"/\\\\*.*?\\\\*/\"),\n"
"              (\"All Whitespace\", false, \"[ \\\\t\\\\r\\\\f\\\\v]*\"),\n"
"              (\"Leading Whitespace\", false, \"^[ \\\\t\\\\r\\\\f\\\\v]*\"),\n"
"              (\"Trailing Whitespace\", false, \"[ \\\\t\\\\r\\\\f\\\\v]*$\"),\n"
"              (\"Script Comment\", false, \"#.*\")\n"
"            ]"

#: data/org.gnome.Meld.gschema.xml:279
msgid "Text-based filters"
msgstr "Op tekst gebaseerde filters"

#: data/org.gnome.Meld.gschema.xml:280
msgid ""
"List of predefined text-based regex filters that, if active, will remove "
"text from being used in a file comparison. The text will still be displayed, "
"but won’t contribute to the comparison itself."
msgstr "Lijst met vooraf gedefinieerde op tekst gebaseerde regexfilters die, indien actief, gebruikte tekst zullen verwijderen die wordt gebruikt bij een bestandsvergelijking. De tekst zal nog steeds worden weergegeven, maar zal niet bijdragen aan de vergelijking zelf."

